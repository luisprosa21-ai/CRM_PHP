DB_HOST=localhost
DB_PORT=3306
DB_NAME=crm_hipotecario
DB_USER=root
DB_PASS=
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=3600
APP_ENV=development
APP_DEBUG=true
UPLOAD_DIR=./storage/documents
MAX_UPLOAD_SIZE=10485760
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Container Profiler — logs instance creation to STDERR
CONTAINER_PROFILER=false
