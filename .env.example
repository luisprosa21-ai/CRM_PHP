# ─── Docker Compose — Variables de entorno ────────────────────
# Copia este archivo como .env en la raíz del proyecto:
#   cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=crm_hipotecario
MYSQL_PORT=3306

# ⚠️ IMPORTANTE: En producción, cambia JWT_SECRET por un valor seguro y aleatorio.
# Genera uno con:  openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=3600

# Puertos expuestos en el host
BACKEND_PORT=8000
BFF_PORT=3001
FRONTEND_PORT=8080

# Container Profiler — logs instance creation to STDERR (backend)
CONTAINER_PROFILER=false
